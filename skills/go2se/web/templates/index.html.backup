<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>护食 Pro | 量化交易平台</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;600&family=Outfit:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        :root {
            --bg-primary: #0a0b0f;
            --bg-secondary: #12131a;
            --bg-tertiary: #1a1b24;
            --bg-card: #15161f;
            --accent-primary: #00f5d4;
            --accent-secondary: #00bbf9;
            --accent-glow: rgba(0, 245, 212, 0.15);
            --text-primary: #f0f2f5;
            --text-secondary: #8b8d94;
            --text-muted: #4a4c56;
            --border-subtle: rgba(255, 255, 255, 0.06);
            --border-active: rgba(0, 245, 212, 0.3);
            --success: #00f5a0;
            --danger: #ff4757;
            --warning: #ffd43b;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Outfit', sans-serif;
            background: var(--bg-primary);
            color: var(--text-primary);
            min-height: 100vh;
            overflow-x: hidden;
        }

        /* Custom Scrollbar */
        ::-webkit-scrollbar { width: 6px; height: 6px; }
        ::-webkit-scrollbar-track { background: var(--bg-secondary); }
        ::-webkit-scrollbar-thumb { background: var(--text-muted); border-radius: 3px; }
        ::-webkit-scrollbar-thumb:hover { background: var(--text-secondary); }

        /* Animated Background */
        .bg-mesh {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: 
                radial-gradient(ellipse at 20% 20%, rgba(0, 245, 212, 0.08) 0%, transparent 50%),
                radial-gradient(ellipse at 80% 80%, rgba(0, 187, 249, 0.06) 0%, transparent 50%),
                radial-gradient(ellipse at 50% 50%, rgba(120, 0, 255, 0.04) 0%, transparent 60%);
            pointer-events: none;
            z-index: 0;
        }

        .noise-overlay {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)'/%3E%3C/svg%3E");
            opacity: 0.03;
            pointer-events: none;
            z-index: 1;
        }

        /* Layout */
        .app-container {
            position: relative;
            z-index: 10;
            display: flex;
            min-height: 100vh;
        }

        /* Sidebar */
        .sidebar {
            width: 72px;
            background: var(--bg-secondary);
            border-right: 1px solid var(--border-subtle);
            display: flex;
            flex-direction: column;
            padding: 1rem 0;
            transition: width 0.3s ease;
        }

        .sidebar:hover { width: 220px; }

        .logo {
            padding: 1rem;
            display: flex;
            align-items: center;
            gap: 0.75rem;
            margin-bottom: 1rem;
        }

        .logo-icon {
            width: 40px;
            height: 40px;
            background: linear-gradient(135deg, var(--accent-primary), var(--accent-secondary));
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.25rem;
            flex-shrink: 0;
        }

        .logo-text {
            font-weight: 700;
            font-size: 1.1rem;
            white-space: nowrap;
            opacity: 0;
            transition: opacity 0.3s;
        }

        .sidebar:hover .logo-text { opacity: 1; }

        .nav-item {
            display: flex;
            align-items: center;
            gap: 0.75rem;
            padding: 0.75rem 1rem;
            margin: 0.25rem 0.5rem;
            border-radius: 8px;
            cursor: pointer;
            transition: all 0.2s;
            color: var(--text-secondary);
        }

        .nav-item:hover, .nav-item.active {
            background: var(--accent-glow);
            color: var(--accent-primary);
        }

        .nav-item.active {
            border: 1px solid var(--border-active);
        }

        .nav-icon { font-size: 1.25rem; width: 24px; text-align: center; flex-shrink: 0; }
        .nav-label { white-space: nowrap; opacity: 0; transition: opacity 0.3s; font-size: 0.875rem; }
        .sidebar:hover .nav-label { opacity: 1; }

        /* Main Content */
        .main-content {
            flex: 1;
            padding: 1.5rem;
            overflow-y: auto;
        }

        /* Header */
        .header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 1.5rem;
        }

        .page-title {
            font-size: 1.5rem;
            font-weight: 600;
        }

        .header-actions {
            display: flex;
            gap: 0.75rem;
        }

        /* Cards */
        .card {
            background: var(--bg-card);
            border: 1px solid var(--border-subtle);
            border-radius: 12px;
            padding: 1.25rem;
            margin-bottom: 1rem;
        }

        .card-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 1rem;
        }

        .card-title {
            font-size: 0.875rem;
            font-weight: 500;
            color: var(--text-secondary);
            text-transform: uppercase;
            letter-spacing: 0.05em;
        }

        /* Stats Grid */
        .stats-grid {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 1rem;
            margin-bottom: 1.5rem;
        }

        .stat-card {
            background: var(--bg-card);
            border: 1px solid var(--border-subtle);
            border-radius: 12px;
            padding: 1.25rem;
            position: relative;
            overflow: hidden;
        }

        .stat-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 2px;
            background: linear-gradient(90deg, var(--accent-primary), var(--accent-secondary));
        }

        .stat-label {
            font-size: 0.75rem;
            color: var(--text-muted);
            text-transform: uppercase;
            letter-spacing: 0.05em;
            margin-bottom: 0.5rem;
        }

        .stat-value {
            font-family: 'JetBrains Mono', monospace;
            font-size: 1.5rem;
            font-weight: 600;
        }

        .stat-value.positive { color: var(--success); }
        .stat-value.negative { color: var(--danger); }

        /* Market Grid */
        .market-grid {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 1rem;
        }

        .market-card {
            background: var(--bg-tertiary);
            border: 1px solid var(--border-subtle);
            border-radius: 10px;
            padding: 1rem;
            cursor: pointer;
            transition: all 0.3s;
        }

        .market-card:hover {
            border-color: var(--accent-primary);
            transform: translateY(-2px);
            box-shadow: 0 8px 24px rgba(0, 245, 212, 0.1);
        }

        .market-icon {
            font-size: 1.75rem;
            margin-bottom: 0.5rem;
        }

        .market-name {
            font-weight: 600;
            margin-bottom: 0.25rem;
        }

        .market-desc {
            font-size: 0.75rem;
            color: var(--text-muted);
            margin-bottom: 0.5rem;
        }

        .market-change {
            font-family: 'JetBrains Mono', monospace;
            font-size: 0.875rem;
            font-weight: 500;
        }

        .market-change.positive { color: var(--success); }
        .market-change.negative { color: var(--danger); }

        /* Signals Table */
        .signals-table {
            width: 100%;
            border-collapse: collapse;
        }

        .signals-table th {
            text-align: left;
            padding: 0.75rem 1rem;
            font-size: 0.75rem;
            color: var(--text-muted);
            text-transform: uppercase;
            letter-spacing: 0.05em;
            border-bottom: 1px solid var(--border-subtle);
        }

        .signals-table td {
            padding: 1rem;
            border-bottom: 1px solid var(--border-subtle);
        }

        .signals-table tr:hover {
            background: var(--bg-tertiary);
        }

        .coin-badge {
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        .coin-icon {
            width: 32px;
            height: 32px;
            background: var(--bg-tertiary);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 600;
            font-size: 0.75rem;
        }

        .action-badge {
            padding: 0.25rem 0.75rem;
            border-radius: 20px;
            font-size: 0.75rem;
            font-weight: 600;
        }

        .action-badge.buy {
            background: rgba(0, 245, 160, 0.15);
            color: var(--success);
        }

        .action-badge.sell {
            background: rgba(255, 71, 87, 0.15);
            color: var(--danger);
        }

        .action-badge.hold {
            background: rgba(255, 212, 59, 0.15);
            color: var(--warning);
        }

        .confidence-bar {
            width: 60px;
            height: 6px;
            background: var(--bg-tertiary);
            border-radius: 3px;
            overflow: hidden;
        }

        .confidence-fill {
            height: 100%;
            border-radius: 3px;
            transition: width 0.5s;
        }

        /* Buttons */
        .btn {
            padding: 0.5rem 1rem;
            border-radius: 8px;
            font-weight: 500;
            font-size: 0.875rem;
            cursor: pointer;
            transition: all 0.2s;
            border: none;
        }

        .btn-primary {
            background: linear-gradient(135deg, var(--accent-primary), #00b8a3);
            color: var(--bg-primary);
        }

        .btn-primary:hover {
            box-shadow: 0 4px 16px rgba(0, 245, 212, 0.3);
            transform: translateY(-1px);
        }

        .btn-outline {
            background: transparent;
            border: 1px solid var(--border-subtle);
            color: var(--text-secondary);
        }

        .btn-outline:hover {
            border-color: var(--accent-primary);
            color: var(--accent-primary);
        }

        /* Animations */
        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .fade-in {
            animation: fadeIn 0.4s ease forwards;
        }

        @keyframes pulse {
            0%, 100% { opacity: 1; }
            50% { opacity: 0.5; }
        }

        .pulse {
            animation: pulse 2s infinite;
        }

        /* Responsive */
        @media (max-width: 1200px) {
            .stats-grid { grid-template-columns: repeat(2, 1fr); }
            .market-grid { grid-template-columns: repeat(2, 1fr); }
        }

        @media (max-width: 768px) {
            .sidebar { width: 72px; }
            .sidebar:hover { width: 72px; }
            .nav-label, .logo-text { display: none; }
            .stats-grid { grid-template-columns: 1fr; }
            .market-grid { grid-template-columns: 1fr; }
        }

        /* Landing Page */
        #landing {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: var(--bg-primary);
            display: flex;
            align-items: center;
            justify-content: center;
            z-index: 9999;
            transition: opacity 0.8s, visibility 0.8s;
        }

        #landing.hidden {
            opacity: 0;
            visibility: hidden;
        }

        .landing-content {
            text-align: center;
        }

        .landing-logo {
            width: 100px;
            height: 100px;
            background: linear-gradient(135deg, var(--accent-primary), var(--accent-secondary));
            border-radius: 24px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 3rem;
            margin: 0 auto 1.5rem;
            animation: float 3s ease-in-out infinite;
        }

        @keyframes float {
            0%, 100% { transform: translateY(0); }
            50% { transform: translateY(-15px); }
        }

        .landing-title {
            font-size: 3rem;
            font-weight: 800;
            background: linear-gradient(135deg, var(--text-primary), var(--accent-primary));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            margin-bottom: 0.5rem;
        }

        .landing-subtitle {
            color: var(--text-secondary);
            font-size: 1.125rem;
        }
    </style>
</head>
<body>
    <!-- Landing -->
    <div id="landing" onclick="hideLanding()">
        <div class="landing-content">
            <div class="landing-logo">🪿</div>
            <h1 class="landing-title">护食 Pro</h1>
            <p class="landing-subtitle">专业量化交易平台</p>
        </div>
    </div>

    <div class="bg-mesh"></div>
    <div class="noise-overlay"></div>

    <div class="app-container">
        <!-- Sidebar -->
        <nav class="sidebar">
            <div class="logo">
                <div class="logo-icon">🪿</div>
                <span class="logo-text">护食</span>
            </div>

            <div class="nav-item active" data-page="home">
                <span class="nav-icon">🏠</span>
                <span class="nav-label">首页</span>
            </div>
            <div class="nav-item" data-page="markets">
                <span class="nav-icon">📊</span>
                <span class="nav-label">市场</span>
            </div>
            <div class="nav-item" data-page="signals">
                <span class="nav-icon">📡</span>
                <span class="nav-label">信号</span>
            </div>
            <div class="nav-item" data-page="strategies">
                <span class="nav-icon">♟️</span>
                <span class="nav-label">策略</span>
            </div>
            <div class="nav-item" data-page="oracle">
                <span class="nav-icon">🔮</span>
                <span class="nav-label">预言机</span>
            </div>
            <div class="nav-item" data-page="portfolio">
                <span class="nav-icon">💼</span>
                <span class="nav-label">组合</span>
            </div>
            <div class="nav-item" data-page="airdrop">
                <span class="nav-icon">🐑</span>
                <span class="nav-label">空投</span>
            </div>
        </nav>

        <!-- Main Content -->
        <main class="main-content">
            <!-- Header -->
            <header class="header">
                <h1 class="page-title" id="pageTitle">仪表盘</h1>
                <div class="header-actions">
                    <button class="btn btn-outline" onclick="refreshData()">🔄 刷新</button>
                    <button class="btn btn-primary" onclick="showAuthModal()">注册/登录</button>
                </div>
            </header>

            <!-- Home Page -->
            <div id="page-home" class="page">
                <!-- Stats -->
                <div class="stats-grid fade-in">
                    <div class="stat-card">
                        <div class="stat-label">账户余额</div>
                        <div class="stat-value" id="userBalance">$1,000</div>
                    </div>
                    <div class="stat-card">
                        <div class="stat-label">总盈亏</div>
                        <div class="stat-value positive" id="totalPnl">+$766</div>
                    </div>
                    <div class="stat-card">
                        <div class="stat-label">胜率</div>
                        <div class="stat-value" id="winRate">68%</div>
                    </div>
                    <div class="stat-card">
                        <div class="stat-label">活跃信号</div>
                        <div class="stat-value" id="signalCount">8</div>
                    </div>
                </div>

                <!-- Markets -->
                <div class="card">
                    <div class="card-header">
                        <span class="card-title">🎯 市场机会</span>
                        <button class="btn btn-outline" onclick="showPage('markets')">查看全部 →</button>
                    </div>
                    <div class="market-grid" id="topMarkets"></div>
                </div>

                <!-- Signals -->
                <div class="card">
                    <div class="card-header">
                        <span class="card-title">📡 实时信号</span>
                        <button class="btn btn-outline" onclick="refreshData()">🔄</button>
                    </div>
                    <table class="signals-table">
                        <thead>
                            <tr>
                                <th>币种</th>
                                <th>操作</th>
                                <th>置信度</th>
                                <th>潜在收益</th>
                                <th>风险</th>
                            </tr>
                        </thead>
                        <tbody id="signalsBody"></tbody>
                    </table>
                </div>
            </div>

            <!-- Markets Page -->
            <div id="page-markets" class="page" style="display:none">
                <div class="card">
                    <div class="card-header">
                        <span class="card-title">📊 北斗七鑫</span>
                    </div>
                    <div class="market-grid" id="allMarkets"></div>
                </div>
            </div>

            <!-- Signals Page -->
            <div id="page-signals" class="page" style="display:none">
                <div class="card">
                    <div class="card-header">
                        <span class="card-title">📡 交易信号</span>
                    </div>
                    <table class="signals-table">
                        <thead>
                            <tr>
                                <th>币种</th>
                                <th>操作</th>
                                <th>置信度</th>
                                <th>潜在收益</th>
                                <th>风险</th>
                                <th>来源</th>
                            </tr>
                        </thead>
                        <tbody id="signalsFull"></tbody>
                    </table>
                </div>
            </div>

            <!-- Strategies Page -->
            <div id="page-strategies" class="page" style="display:none">
                <div class="card">
                    <div class="card-header">
                        <span class="card-title">♟️ 12策略整合</span>
                    </div>
                    <div id="strategiesList"></div>
                </div>
            </div>

            <!-- Oracle Page -->
            <div id="page-oracle" class="page" style="display:none">
                <div class="card">
                    <div class="card-header">
                        <span class="card-title">🔮 预言机事件</span>
                    </div>
                    <div id="oracleList"></div>
                </div>
            </div>

            <!-- Portfolio Page -->
            <div id="page-portfolio" class="page" style="display:none">
                <div class="card mb-4">
                    <div class="card-header">
                        <span class="card-title">💼 投资组合</span>
                    </div>
                    <div class="flex gap-2 mb-4">
                        <button class="btn btn-outline" onclick="applyPreset('conservative')">🛡️ 保守</button>
                        <button class="btn btn-outline" onclick="applyPreset('balanced')">⚖️ 平衡</button>
                        <button class="btn btn-outline" onclick="applyPreset('aggressive')">🚀 激进</button>
                    </div>
                    <div id="portfolioBody"></div>
                </div>
                <div class="card">
                    <div class="card-header">
                        <span class="card-title">⚙️ 参数配置</span>
                    </div>
                    <div id="paramsBody"></div>
                </div>
            </div>

            <!-- Airdrop Page -->
            <div id="page-airdrop" class="page" style="display:none">
                <div class="stats-grid">
                    <div class="stat-card">
                        <div class="stat-label">🐑 空投收益</div>
                        <div class="stat-value positive" id="airdropTotal">$0</div>
                    </div>
                    <div class="stat-card">
                        <div class="stat-label">🎁 待领取</div>
                        <div class="stat-value" id="airdropPending">$0</div>
                    </div>
                </div>
                <div class="card">
                    <div class="card-header">
                        <span class="card-title">🔍 薅羊毛</span>
                    </div>
                    <div class="text-center py-4">
                        <button class="btn btn-primary btn-lg" onclick="huntAirdrop()">开始搜索空投</button>
                        <div id="airdropResults" class="mt-4"></div>
                    </div>
                </div>
            </div>
        </main>
    </div>

    <!-- Auth Modal -->
    <div id="authModal" style="display:none;position:fixed;top:0;left:0;width:100%;height:100%;background:rgba(0,0,0,0.8);z-index:2000;align-items:center;justify-content:center;">
        <div style="background:var(--bg-card);border:1px solid var(--border-subtle);border-radius:16px;padding:2rem;max-width:400px;width:90%;">
            <h3 style="margin-bottom:1.5rem">注册 / 登录</h3>
            <input id="regUser" placeholder="用户名" style="width:100%;padding:0.75rem;background:var(--bg-tertiary);border:1px solid var(--border-subtle);border-radius:8px;color:var(--text-primary);margin-bottom:0.75rem;">
            <input id="regPass" type="password" placeholder="密码" style="width:100%;padding:0.75rem;background:var(--bg-tertiary);border:1px solid var(--border-subtle);border-radius:8px;color:var(--text-primary);margin-bottom:0.75rem;">
            <input id="regWallet" placeholder="钱包地址(可选)" style="width:100%;padding:0.75rem;background:var(--bg-tertiary);border:1px solid var(--border-subtle);border-radius:8px;color:var(--text-primary);margin-bottom:1rem;">
            <div style="display:flex;gap:0.5rem">
                <button class="btn btn-primary flex-1" onclick="doRegister()">注册</button>
                <button class="btn btn-outline flex-1" onclick="doLogin()">登录</button>
            </div>
            <button class="btn btn-link" style="width:100%;margin-top:0.5rem;color:var(--text-secondary)" onclick="hideAuthModal()">取消</button>
        </div>
    </div>

    <script>
        let markets = [], signals = [], strategies = [], user = {balance: 1000, airdrop: 0};

        function hideLanding() {
            document.getElementById('landing').classList.add('hidden');
        }
        setTimeout(() => hideLanding(), 2500);

        async function api(url, method = 'GET', data = null) {
            try {
                const opt = {method, headers: {'Content-Type': 'application/json'}};
                if (data) opt.body = JSON.stringify(data);
                return await fetch(url, opt).then(r => r.json());
            } catch { return {}; }
        }

        async function init() {
            await Promise.all([
                loadMarkets(),
                loadSignals(),
                loadStrategies(),
                loadOracle(),
                loadPortfolio()
            ]);
        }

        async function loadMarkets() {
            const d = await api('/api/markets');
            markets = d.markets || [];
            renderMarkets();
        }

        function renderMarkets() {
            let html = '';
            markets.forEach((m, i) => {
                const daily = m.performance?.daily || 0;
                const isPos = daily >= 0;
                const card = `<div class="market-card">
                    <div class="market-icon">${m.icon}</div>
                    <div class="market-name">${m.name}</div>
                    <div class="market-desc">${m.description}</div>
                    <div class="market-change ${isPos ? 'positive' : 'negative'}">${isPos ? '+' : ''}${daily}%</div>
                </div>`;
                html += card;
                if (i < 4) document.getElementById('topMarkets').innerHTML = html;
            });
            document.getElementById('allMarkets').innerHTML = html;
        }

        async function loadSignals() {
            const d = await api('/api/signals');
            signals = d.signals || [];
            document.getElementById('signalCount').innerText = signals.length;
            renderSignals();
        }

        function renderSignals() {
            const renderTo = document.getElementById('signalsBody');
            const renderFull = document.getElementById('signalsFull');
            
            let html = '';
            signals.forEach(s => {
                const actionClass = s.action === 'BUY' ? 'buy' : s.action === 'SELL' ? 'sell' : 'hold';
                const confPct = s.confidence * 10;
                const confColor = confPct > 70 ? 'var(--success)' : confPct > 50 ? 'var(--warning)' : 'var(--danger)';
                
                html += `<tr>
                    <td><div class="coin-badge"><div class="coin-icon">${s.coin.slice(0,2)}</div><span>${s.coin}</span></div></td>
                    <td><span class="action-badge ${actionClass}">${s.action}</span></td>
                    <td><div class="confidence-bar"><div class="confidence-fill" style="width:${confPct}%;background:${confColor}"></div></div><span style="font-size:0.75rem;margin-left:0.5rem">${s.confidence}</span></td>
                    <td style="color:var(--success)">+${s.potential}%</td>
                    <td>${s.risk === 'low' ? '🟢低' : s.risk === 'medium' ? '🟡中' : '🔴高'}</td>
                    <td style="color:var(--text-muted);font-size:0.75rem">${(s.sources || []).slice(0,2).join(',')}</td>
                </tr>`;
            });
            
            if(renderTo) renderTo.innerHTML = html;
            if(renderFull) renderFull.innerHTML = html;
        }

        async function loadStrategies() {
            const d = await api('/api/strategies');
            strategies = d.strategies || [];
            
            let html = '<div style="display:grid;grid-template-columns:repeat(3,1fr);gap:1rem">';
            strategies.forEach(s => {
                html += `<div style="background:var(--bg-tertiary);border-radius:10px;padding:1rem">
                    <div style="font-weight:600;margin-bottom:0.25rem">${s.name}</div>
                    <div style="font-size:0.75rem;color:var(--text-muted);margin-bottom:0.5rem">${s.source}</div>
                    <div style="font-size:0.8rem;color:var(--text-secondary)">${s.description}</div>
                </div>`;
            });
            html += '</div>';
            document.getElementById('strategiesList').innerHTML = html;
        }

        async function loadOracle() {
            const d = await api('/api/oracle');
            const events = d.events || [];
            
            let html = '<div style="display:grid;grid-template-columns:repeat(2,1fr);gap:1rem">';
            events.forEach(e => {
                const isPos = e.impact >= 0;
                html += `<div style="background:var(--bg-tertiary);border-radius:10px;padding:1rem">
                    <div style="font-weight:600;margin-bottom:0.25rem">${e.type}</div>
                    <div style="font-size:0.8rem;color:var(--text-muted);margin-bottom:0.5rem">${e.description}</div>
                    <div style="font-family:JetBrains Mono;color:${isPos?'var(--success)':'var(--danger)'}">${isPos?'+':''}${e.impact}% ${e.symbol}</div>
                </div>`;
            });
            html += '</div>';
            document.getElementById('oracleList').innerHTML = html;
        }

        async function loadPortfolio() {
            const d = await api('/api/portfolio');
            const perf = d.performance || {};
            
            document.getElementById('totalPnl').innerText = `+$${perf.total_pnl || 0}`;
            document.getElementById('winRate').innerText = `${perf.win_rate || 0}%`;
            
            const p = d.portfolio || {};
            let html = '<table class="signals-table"><tr><th>市场</th><th>权重</th><th>PnL</th></tr>';
            for (let [k, v] of Object.entries(p)) {
                html += `<tr><td>${k}</td><td>${v.weight}%</td><td style="color:var(--success)">+$${v.pnl}</td></tr>`;
            }
            html += '</table>';
            document.getElementById('portfolioBody').innerHTML = html;
            
            // Params
            document.getElementById('paramsBody').innerHTML = `
                <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:1rem">
                    <div><label style="font-size:0.75rem;color:var(--text-muted)">置信度阈值</label><div style="font-weight:600">8.0</div></div>
                    <div><label style="font-size:0.75rem;color:var(--text-muted)">止损%</label><div style="font-weight:600">2.0%</div></div>
                    <div><label style="font-size:0.75rem;color:var(--text-muted)">止盈%</label><div style="font-weight:600">5.0%</div></div>
                </div>
            `;
        }

        function showPage(pageId) {
            document.querySelectorAll('.page').forEach(p => p.style.display = 'none');
            document.getElementById('page-' + pageId).style.display = 'block';
            document.querySelectorAll('.nav-item').forEach(n => n.classList.remove('active'));
            document.querySelector(`[data-page="${pageId}"]`).classList.add('active');
            
            const titles = {home: '仪表盘', markets: '北斗七鑫', signals: '交易信号', strategies: '策略中心', oracle: '预言机', portfolio: '投资组合', airdrop: '薅羊毛'};
            document.getElementById('pageTitle').innerText = titles[pageId] || '护食';
        }

        document.querySelectorAll('.nav-item').forEach(item => {
            item.addEventListener('click', () => showPage(item.dataset.page));
        });

        async function refreshData() {
            await init();
        }

        async function applyPreset(name) {
            await api('/api/preset/' + name);
            await loadPortfolio();
        }

        async function huntAirdrop() {
            const d = await api('/api/airdrop/hunt');
            let html = '';
            if (d.airdrops) {
                d.airdrops.forEach(a => {
                    html += `<div style="background:var(--bg-tertiary);border-radius:8px;padding:0.75rem;margin:0.5rem 0;color:var(--success)">✅ ${a.coin} +$${a.amount}</div>`;
                });
            }
            document.getElementById('airdropResults').innerHTML = html;
        }

        function showAuthModal() { document.getElementById('authModal').style.display = 'flex'; }
        function hideAuthModal() { document.getElementById('authModal').style.display = 'none'; }

        async function doRegister() {
            const u = document.getElementById('regUser').value;
            const p = document.getElementById('regPass').value;
            const w = document.getElementById('regWallet').value;
            const d = await api('/api/user/register', 'POST', {username: u, password: p, wallet: w});
            if (d.success) { alert('注册成功!'); hideAuthModal(); }
            else alert('注册失败');
        }

        async function doLogin() {
            const u = document.getElementById('regUser').value;
            const p = document.getElementById('regPass').value;
            const d = await api('/api/user/login', 'POST', {username: u, password: p});
            if (d.success) { alert('登录成功!'); hideAuthModal(); }
            else alert('登录失败');
        }

        init();
    </script>
</body>
</html>