# 🪿 GO2SE 生产环境配置
# ============================================

# 交易模式: dry_run 或 live
TRADING_MODE=dry_run

# 数据库
DATABASE_URL=sqlite:///./go2se.db

# 风控参数 (优化后V2)
MAX_POSITION=0.6
STOP_LOSS=0.03
TAKE_PROFIT=0.06
TRAILING_STOP=0.03
POSITION_SIZE=0.10
LEVERAGE=2

# 币安API (需要用户填入)
BINANCE_API_KEY=your_api_key_here
BINANCE_SECRET_KEY=your_secret_key_here

# 日志
LOG_LEVEL=INFO

# 服务器
HOST=0.0.0.0
PORT=8000
WORKERS=2
