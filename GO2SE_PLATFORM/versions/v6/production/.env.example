# ═══════════════════════════════════════════════════════════════════════════════
# 🪿 GO2SE 环境配置模板
# 复制此文件为 .env 并填入实际值
# ═══════════════════════════════════════════════════════════════════════════════

# ─────────────────────────────────────────────────────────────────────────────
# 数据库配置
# ─────────────────────────────────────────────────────────────────────────────
POSTGRES_USER=go2se
POSTGRES_PASSWORD=YourSecurePassword123!@#
POSTGRES_DB=go2se_trading

# ─────────────────────────────────────────────────────────────────────────────
# 交易模式 (重要!)
# ─────────────────────────────────────────────────────────────────────────────
# dry_run: 模拟交易 (测试用)
# live: 实盘交易 (真实资金)
TRADING_MODE=dry_run

# ─────────────────────────────────────────────────────────────────────────────
# 风控参数
# ─────────────────────────────────────────────────────────────────────────────
MAX_POSITION=0.6          # 最大仓位 60%
STOP_LOSS=0.10            # 止损 -10%
TAKE_PROFIT=0.30          # 止盈 +30%

# ─────────────────────────────────────────────────────────────────────────────
# 币安API配置 (必填!)
# ─────────────────────────────────────────────────────────────────────────────
# 前往 https://www.binance.com/api/v3/account 创建API密钥
# 建议: 只开启"只读"权限,关闭"提现"权限
BINANCE_API_KEY=your_binance_api_key_here
BINANCE_SECRET_KEY=your_binance_secret_key_here

# ─────────────────────────────────────────────────────────────────────────────
# 交易对配置
# ─────────────────────────────────────────────────────────────────────────────
TRADING_PAIRS=BTC/USDT,ETH/USDT,SOL/USDT,XRP/USDT,BNB/USDT,ADA/USDT,DOGE/USDT,DOT/USDT,AVAX/USDT,LINK/USDT

# ─────────────────────────────────────────────────────────────────────────────
# 策略配置
# ─────────────────────────────────────────────────────────────────────────────
# 策略权重
RABBIT_WEIGHT=0.25        # 打兔子 25%
MOLE_WEIGHT=0.20          # 打地鼠 20%
ORACLE_WEIGHT=0.15        # 走着瞧 15%
LEADER_WEIGHT=0.15        # 跟大哥 15%
HITCHHIKER_WEIGHT=0.10    # 搭便车 10%
AIRDROP_WEIGHT=0.03       # 薅羊毛 3%
CROWDSOURCE_WEIGHT=0.02   # 穷孩子 2%

# 策略执行间隔 (秒)
STRATEGY_INTERVAL_RABBIT=300       # 5分钟
STRATEGY_INTERVAL_MOLE=60          # 1分钟
STRATEGY_INTERVAL_ORACLE=600       # 10分钟
STRATEGY_INTERVAL_LEADER=60        # 10秒
STRATEGY_INTERVAL_HITCHHIKER=1800  # 30分钟

# ─────────────────────────────────────────────────────────────────────────────
# 日志配置
# ─────────────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO               # DEBUG, INFO, WARNING, ERROR
LOG_FILE=/app/logs/go2se.log
LOG_MAX_SIZE=100M
LOG_BACKUP_COUNT=10

# ─────────────────────────────────────────────────────────────────────────────
# 监控配置
# ─────────────────────────────────────────────────────────────────────────────
GRAFANA_USER=admin
GRAFANA_PASSWORD=YourGrafanaPassword123!

# ─────────────────────────────────────────────────────────────────────────────
# 高级配置
# ─────────────────────────────────────────────────────────────────────────────
# API限流
API_RATE_LIMIT=1200          # 每分钟最大请求数
API_TIMEOUT=5               # 请求超时秒数

# 缓存配置
CACHE_TTL_PRICE=5           # 价格缓存秒数
CACHE_TTL_OHLCV=30          # K线缓存秒数
CACHE_TTL_ORDERBOOK=2       # 订单簿缓存秒数

# 自动重连
RETRY_MAX_ATTEMPTS=3
RETRY_BACKOFF_MULTIPLIER=2

# 健康检查
HEALTH_CHECK_INTERVAL=30
HEALTH_CHECK_TIMEOUT=10
